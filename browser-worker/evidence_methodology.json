    "leave_requests": {"required_sources": ["deep_rest","business_architecture","process_mining"], "usage_sources": ["deep_rest","process_mining"]},
    "business_trips": {"required_sources": ["deep_rest","business_architecture","process_mining"], "usage_sources": ["deep_rest","process_mining"]},
    "it_service_requests": {"required_sources": ["deep_rest","business_architecture","operations"], "usage_sources": ["deep_rest","process_mining","operations"]},
    "access_requests": {"required_sources": ["deep_rest","business_architecture","process_mining"], "usage_sources": ["deep_rest","process_mining"]},
