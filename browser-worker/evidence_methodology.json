{
  "version": "2.0.0-alpha.4",
  "title": "AI-BIT Evidence-Based Implementation Methodology",
  "description": "Доказательная методика оценки внедрения Bitrix24. Итоговый статус формируется только по данным, которые система получила и проверила самостоятельно.",
  "status_rules": {
    "implemented": "Найдены независимые подтверждения конфигурации и фактического использования.",
    "partial": "Найдена конфигурация или отдельные факты, но полный маршрут либо использование не подтверждены.",
    "missing": "Все обязательные технические источники доступны и проверены, подтверждений конфигурации и использования не найдено.",
    "unknown": "Недостаточно доступных источников для доказательного вывода. Не считается отсутствием."
  },
  "source_catalog": {
    "deep_rest": {"title": "Прямые REST-проверки сущностей Bitrix24", "artifact": "deep-rest-evidence/latest.json", "weight": 5},
