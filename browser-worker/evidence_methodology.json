    "internal_memos": {"required_sources": ["deep_rest","crawl","business_architecture"], "usage_sources": ["deep_rest","process_mining"]},
    "user_provisioning_request": {"required_sources": ["deep_rest","business_architecture","operations"], "usage_sources": ["deep_rest","process_mining","operations"]},
