    "business_architecture": {"title": "Бизнес-архитектура и шаблоны процессов", "artifact": "business-architecture/latest.json", "weight": 2},
    "process_mining": {"title": "Фактические запуски и процессная активность", "artifact": "process-mining/latest.json", "weight": 3},
    "operations": {"title": "Операционная активность пользователей", "artifact": "operations/latest.json", "weight": 2},
    "capability_discovery": {"title": "Автоматическое обнаружение сущностей", "artifact": "capability-discovery/latest.json", "weight": 2}
  },
  "capabilities": {
