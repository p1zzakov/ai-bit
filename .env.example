APP_NAME=AI-BIT
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
BITRIX_WEBHOOK_URL=https://bitrix.example.kz/rest/USER_ID/WEBHOOK_TOKEN/
BITRIX_VERIFY_TLS=true
BITRIX_REQUEST_TIMEOUT=30
REPORTS_DIR=/app/reports

# Browser worker. Use a dedicated Bitrix24 user with minimum read-only permissions.
BROWSER_BASE_URL=https://bitrix.example.kz
BROWSER_LOGIN=
BROWSER_PASSWORD=
BROWSER_LOGIN_PATH=/auth/
BROWSER_HEADLESS=true
BROWSER_IGNORE_HTTPS_ERRORS=false
BROWSER_TIMEOUT_MS=45000

# AI provider.
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Optional average loaded labour cost for ROI calculations, KZT per hour.
ROI_HOURLY_COST_KZT=0

# Universal MCP Provider Framework. Explicit read-only allowlist only.
# Use a dedicated 1C user with read permissions and rotate the password after setup.
MCP_SERVERS_JSON=[{"id":"mcp_1c","name":"1C Test Base","transport":"stdio","command":"/app/bin/mcp-1c","args":["--base","http://192.168.1.4/butalova/hs/mcp-1c","--user","AI_BIT_AUDIT","--password","CHANGE_ME","--quiet"],"timeout_seconds":120,"allowed_tools":["get_configuration_info","get_metadata_tree","get_object_structure","get_event_log","analyze_subsystems","validate_query","execute_query"],"calls":[{"id":"configuration","name":"get_configuration_info","arguments":{}},{"id":"metadata_summary","name":"get_metadata_tree","arguments":{}},{"id":"onec_event_log_errors","name":"get_event_log","arguments":{"level":"Ошибка","limit":200}},{"id":"onec_event_log_warnings","name":"get_event_log","arguments":{"level":"Предупреждение","limit":200}},{"id":"subsystem_orphans","name":"analyze_subsystems","arguments":{"action":"orphans"}}]}]

# Bitrix24 ↔ 1C topology. These are hypotheses until confirmed by evidence from both systems.
BITRIX_ONEC_ENTITY_MAP_JSON=[{"id":"company_counterparty","bitrix":"crm.company","onec":"Catalog.Контрагенты","label":"Компания ↔ Контрагент"},{"id":"contact_person","bitrix":"crm.contact","onec":"Catalog.КонтактныеЛица","label":"Контакт ↔ Контактное лицо"},{"id":"deal_order","bitrix":"crm.deal","onec":"Document.ЗаказКлиента","label":"Сделка ↔ Заказ клиента"},{"id":"product_nomenclature","bitrix":"crm.product","onec":"Catalog.Номенклатура","label":"Товар ↔ Номенклатура"},{"id":"invoice_customer","bitrix":"crm.invoice","onec":"Document.СчетНаОплатуПокупателю","label":"Счёт ↔ Счёт покупателю"}]

# Field mapping is intentionally empty until real integration fields are identified.
# Example: [{"entity":"Компания ↔ Контрагент","bitrix_field":"UF_CRM_BIN","onec_field":"БИН"}]
BITRIX_ONEC_FIELD_MAP_JSON=[]

# Data checks reference explicit MCP call IDs and Bitrix evidence sources.
# No query is executed unless it is explicitly present in MCP_SERVERS_JSON calls and allowlisted.
BITRIX_ONEC_DATA_CHECKS_JSON=[]

# Optional generic HTTP read-only sources. Only GET requests are performed.
HTTP_SOURCES_JSON=[]

# Backward-compatible single mcp-1c configuration. Used only when MCP_SERVERS_JSON is empty.
ONEC_MCP_COMMAND=/app/bin/mcp-1c
ONEC_MCP_ARGS_JSON=["--base","http://192.168.1.4/butalova/hs/mcp-1c","--user","AI_BIT_AUDIT","--password","CHANGE_ME","--quiet"]
ONEC_MCP_ENV_JSON={}
ONEC_MCP_TIMEOUT_SECONDS=120
ONEC_MCP_ALLOWED_TOOLS_JSON=[]
ONEC_MCP_CALLS_JSON=[]

# Scheduling & Automation.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Almaty
SCHEDULER_POLL_SECONDS=30
SCHEDULER_OPERATIONS_ENABLED=true
SCHEDULER_OPERATIONS_SCHEDULE=daily@06:00
SCHEDULER_BUSINESS_ARCHITECTURE_ENABLED=true
SCHEDULER_BUSINESS_ARCHITECTURE_SCHEDULE=weekly:mon@07:00
SCHEDULER_CRAWL_ENABLED=true
SCHEDULER_CRAWL_SCHEDULE=weekly:sun@03:00
SCHEDULER_EXECUTIVE_REPORT_ENABLED=true
SCHEDULER_EXECUTIVE_REPORT_SCHEDULE=monthly:1@08:00
