APP_NAME=AI-BIT
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
BITRIX_WEBHOOK_URL=https://bitrix.example.kz/rest/USER_ID/WEBHOOK_TOKEN/
BITRIX_VERIFY_TLS=true
BITRIX_REQUEST_TIMEOUT=30
REPORTS_DIR=/app/reports

# Browser worker. Use a dedicated Bitrix24 user with minimum read-only permissions.
BROWSER_BASE_URL=https://bitrix.example.kz
BROWSER_LOGIN=
BROWSER_PASSWORD=
BROWSER_LOGIN_PATH=/auth/
BROWSER_HEADLESS=true
BROWSER_IGNORE_HTTPS_ERRORS=false
BROWSER_TIMEOUT_MS=45000

# AI provider. Groq is the default fast inference provider.
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# Optional average loaded labour cost for ROI calculations, KZT per hour.
ROI_HOURLY_COST_KZT=0

# Universal MCP Provider Framework.
# The binary path must exist inside browser-worker, for example through a read-only bind mount.
# Every tool call requires an explicit allowlist entry. AI-BIT never calls discovered tools automatically.
MCP_SERVERS_JSON=[{"id":"mcp_1c","name":"1C Test Base","transport":"stdio","command":"/app/bin/mcp-1c","args":["--base","http://192.168.1.4/butalova/hs/mcp-1c","--user","AI_BIT_AUDIT","--password","CHANGE_ME"],"timeout_seconds":60,"allowed_tools":["1c_metadata_navigation","explain_config","explain_object"],"calls":[{"name":"1c_metadata_navigation","arguments":{}},{"name":"explain_config","arguments":{}}]}]

# Optional generic HTTP read-only sources. Only GET requests are performed.
HTTP_SOURCES_JSON=[]

# Backward-compatible single mcp-1c configuration. Used only when MCP_SERVERS_JSON is empty.
ONEC_MCP_COMMAND=/app/bin/mcp-1c
ONEC_MCP_ARGS_JSON=["--base","http://192.168.1.4/butalova/hs/mcp-1c","--user","AI_BIT_AUDIT","--password","CHANGE_ME"]
ONEC_MCP_ENV_JSON={}
ONEC_MCP_TIMEOUT_SECONDS=60
ONEC_MCP_ALLOWED_TOOLS_JSON=[]
ONEC_MCP_CALLS_JSON=[]

# Scheduling & Automation.
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Almaty
SCHEDULER_POLL_SECONDS=30
SCHEDULER_OPERATIONS_ENABLED=true
SCHEDULER_OPERATIONS_SCHEDULE=daily@06:00
SCHEDULER_BUSINESS_ARCHITECTURE_ENABLED=true
SCHEDULER_BUSINESS_ARCHITECTURE_SCHEDULE=weekly:mon@07:00
SCHEDULER_CRAWL_ENABLED=true
SCHEDULER_CRAWL_SCHEDULE=weekly:sun@03:00
SCHEDULER_EXECUTIVE_REPORT_ENABLED=true
SCHEDULER_EXECUTIVE_REPORT_SCHEDULE=monthly:1@08:00
